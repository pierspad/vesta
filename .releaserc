{
  "branches": [
    "main",
    {
      "name": "dev",
      "prerelease": true
    }
  ],
  "plugins": [
    [
      "@semantic-release/commit-analyzer", {
        "preset": "conventionalcommits",
        "releaseRules": [
          { "type": "fix", "release": "patch" },
          { "type": "feat", "release": "minor" },
          { "type": "bump", "release": "patch" },
          { "type": "perf", "release": "patch" },
          { "type": "build", "scope": "Needs bump", "release": "patch" }
        ]
      }
    ],
    [
      "@semantic-release/release-notes-generator", {
        "preset": "conventionalcommits",
        "presetConfig": {
          "types": [
            { "type": "fix", "section": "🐛 Bug Fixes", "hidden": false },
            { "type": "feat", "section": "✨ New Features", "hidden": false },
            { "type": "bump", "section": "🚀 Updated App Support", "hidden": false },
            { "type": "perf", "section": "🔧 Improvements", "hidden": false },
            { "type": "build", "hidden": true }
          ]
        }
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "sed -i 's/^pkgver=.*/pkgver=${nextRelease.version}/' build-scripts/PKGBUILD && bash build-scripts/update_project_info.sh",
        "publishCmd": "gh workflow run 'Build and Release' --ref 'v${nextRelease.version}'"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "build-scripts/PKGBUILD",
          "Cargo.toml",
          "Cargo.lock",
          "build-scripts/com.vesta.desktop.desktop",
          "build-scripts/vesta.desktop",
          "build-scripts/com.vesta.desktop.flatpak.yml",
          "apps/srt-gui/src-tauri/tauri.conf.json",
          "apps/srt-gui/src-tauri/Cargo.toml",
          "apps/srt-gui/package.json",
          "apps/srt-gui/src/lib/Sidebar.svelte",
          "apps/srt-gui/src/lib/SettingsTab.svelte",
          "core/*/Cargo.toml",
          "lib/*/Cargo.toml"
        ],
        "message": "chore: Release v${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "successComment": false
      }
    ],
    [
      "@cleyrop-org/semantic-release-backmerge",
      {
        "backmergeBranches": [{"from": "main", "to": "dev"}],
        "clearWorkspace": true,
        "backmergeStrategy": "merge",
        "mergeMode": "theirs"
      }
    ]
  ]
}
